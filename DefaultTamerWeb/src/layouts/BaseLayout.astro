---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import SearchPalette from '../components/SearchPalette.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  jsonLd?: unknown;
}

const { title, description, image, type, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEO 
      title={title}
      description={description}
      image={image}
      type={type}
      jsonLd={jsonLd}
    />
    <!-- Preload self-hosted fonts so LCP text renders fast -->
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plus-jakarta-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Preload hero background image for LCP optimization -->
    <link rel="preload" href="/images/routing-flow.svg" as="image" fetchpriority="high" />
    <link rel="alternate" type="application/rss+xml" title="Default Tamer" href="/rss.xml" />
  </head>
  <body>
    <div>
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <SearchPalette />

    <!-- Back to top button -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 hidden rounded-full bg-dark p-3 text-white shadow-lg hover:bg-dark-light transition-all duration-200 hover:scale-110"
      aria-label="Back to top"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
    
    <script>
      // Navbar scroll effect — uses rAF to batch DOM writes and avoid forced reflows
      const navbar = document.querySelector('nav');
      const backToTop = document.getElementById('back-to-top');
      let ticking = false;

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const currentScroll = window.pageYOffset;
            if (currentScroll > 50) {
              navbar?.classList.add('shadow-lg');
            } else {
              navbar?.classList.remove('shadow-lg');
            }
            if (currentScroll > 400) {
              backToTop?.classList.remove('hidden');
            } else {
              backToTop?.classList.add('hidden');
            }
            ticking = false;
          });
          ticking = true;
        }
      });

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>

    <!-- Load custom interactive components (non-blocking) -->
    <script async src="/scripts/custom-interactions.js"></script>

    <!-- Load analytics + manifest only after page is fully loaded -->
    <script is:inline>
      function loadDeferred() {
        var a = document.createElement('script');
        a.src = '/scripts/anately.js';
        a.defer = true;
        a.dataset.websiteId = 'babc74c5-5c94-4f0b-9a47-6b0b0fa12384';
        a.dataset.hostUrl = 'https://manage.anately.sh';
        document.body.appendChild(a);
        var m = document.createElement('link');
        m.rel = 'manifest';
        m.href = '/site.webmanifest';
        document.head.appendChild(m);
      }
      if (document.readyState === 'complete') {
        loadDeferred();
      } else {
        window.addEventListener('load', loadDeferred);
      }
    </script>
  </body>
</html>
