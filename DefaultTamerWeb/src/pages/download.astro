---
import BaseLayout from '../layouts/BaseLayout.astro';
import latestRelease from '../data/release.json';
import { getCollection } from 'astro:content';

const dmgSize = latestRelease.size
  ? `~${(latestRelease.size / (1024 * 1024)).toFixed(1)} MB`
  : '~2 MB';

// Fetch changelog entry for the current release
const allEntries = await getCollection('changelog');
const currentEntry = allEntries.find(e => e.data.version === latestRelease.version && !e.data.isUnreleased);

let releaseHtml = '';
if (currentEntry?.body) {
  const { marked } = await import('marked');
  const catClasses: Record<string, string> = {
    Added: 'changelog-cat-added', Changed: 'changelog-cat-changed',
    Updated: 'changelog-cat-changed', Improved: 'changelog-cat-changed',
    Fixed: 'changelog-cat-fixed', Removed: 'changelog-cat-removed',
    Security: 'changelog-cat-security',
  };
  releaseHtml = (await marked.parse(currentEntry.body)).replace(
    /<h3>(Added|Changed|Updated|Improved|Fixed|Removed|Security)<\/h3>/g,
    (_, cat: string) => `<div class="changelog-category ${catClasses[cat] ?? 'changelog-cat-default'}">${cat}</div>`
  );
}

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Default Tamer",
    "description": "Free, open source macOS menu bar app that routes URLs to specific browsers based on rules. URL routing is 100% local. Optional anonymous analytics, no subscription.",
    "url": "https://www.defaulttamer.app/download",
    "downloadUrl": `https://www.defaulttamer.app/download/DefaultTamer-v${latestRelease.version}.dmg`,
    "softwareVersion": latestRelease.version,
    "fileSize": latestRelease.size ? `${(latestRelease.size / (1024 * 1024)).toFixed(1)} MB` : undefined,
    "operatingSystem": "macOS 13.0 Ventura or later",
    "applicationCategory": "UtilitiesApplication",
    "applicationSubCategory": "Productivity",
    "license": "https://opensource.org/licenses/MIT",
    "isAccessibleForFree": true,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "featureList": [
      "Route URLs to specific browsers based on rules",
      "Match by source app, domain, URL pattern, or regex",
      "Menu bar app — no dock icon",
      "URL routing is 100% local — your browsing stays on your Mac",
      "Open source under MIT license"
    ],
    "screenshot": "https://www.defaulttamer.app/images/icon-512.png",
    "author": {
      "@type": "Person",
      "name": "0xdps",
      "url": "https://github.com/0xdps"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.defaulttamer.app" },
      { "@type": "ListItem", "position": 2, "name": "Download", "item": "https://www.defaulttamer.app/download" }
    ]
  }
];
---

<BaseLayout 
  title={`Download Default Tamer – Free macOS Browser Router | v${latestRelease.version}`}
  description="Download Default Tamer for macOS free. Route links from Slack to Chrome, work URLs to Firefox, and more. Open source, privacy-first, no subscription."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <div class="hero-section py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Download <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Default Tamer</span>
      </h1>
      <p class="mt-3 text-lg text-gray-300">Open Source Browser Routing for macOS</p>
    </div>
  </div>

  <div class="bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-16">

        <!-- Sticky sidebar TOC -->
        <aside class="hidden lg:block">
          <div class="sticky top-28 space-y-1">
            <p class="text-xs font-bold uppercase tracking-widest text-gray mb-4">On this page</p>
            <nav class="flex flex-col gap-0.5">
              <a href="#download" class="toc-link">Download</a>
              <a href="#installation" class="toc-link">Installation</a>
              <a href="#requirements" class="toc-link">Requirements</a>
              <a href="#verification" class="toc-link">Verification</a>
              <a href="#whats-next" class="toc-link">What's Next</a>
            </nav>
          </div>
        </aside>

        <!-- Main content -->
        <div class="min-w-0 space-y-20">

      <!-- Download Card -->
      <section id="download">
      <div class="rounded-2xl bg-white p-8 sm:p-12 shadow-xl border-2 border-gray-light">
        <div class="flex items-center gap-6 mb-8">
          <img src="/images/icon-512.png" alt="Default Tamer Icon" class="w-20 h-20 rounded-2xl shadow-soft">
          <div>
            <h2 class="text-2xl font-bold text-dark">Default Tamer</h2>
            <div class="flex items-center gap-2 mt-1">
              <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-semibold text-primary ring-1 ring-inset ring-primary/20">v{latestRelease.version}</span>
              <p class="text-gray text-sm">Latest stable release · {latestRelease.releaseDate}</p>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 mb-8">
          <a
            href={latestRelease.downloadUrl}
            data-umami-event="Download App"
            data-umami-event-version={latestRelease.version}
            data-umami-event-source="download-page"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-dark shadow-sm hover:bg-primary-dark transition-all duration-200 hover:scale-105"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download DMG
          </a>
          <a
            href="/changelog"
            data-umami-event="View All Releases"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-gray px-6 py-3 text-sm font-semibold text-dark hover:border-primary hover:text-primary transition-all duration-200"
          >
            View All Releases
          </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="text-sm"><strong class="text-dark">Size:</strong> <span class="text-gray">{dmgSize}</span></div>
          <div class="text-sm flex items-center gap-2"><strong class="text-dark">Requirements:</strong> <span class="text-gray">macOS 13.0+</span></div>
          <div class="text-sm"><strong class="text-dark">License:</strong> <span class="text-gray">MIT (Open Source)</span></div>
        </div>

        {releaseHtml && (
          <div class="mt-8 pt-8 border-t-2 border-gray-light">
            <h3 class="text-sm font-bold uppercase tracking-widest text-gray mb-4">What's in this release</h3>
            <div class="changelog-content">
              <Fragment set:html={releaseHtml} />
            </div>
          </div>
        )}
      </div>
      </section>

      <!-- Installation Guide -->
      <section id="installation">
        <h2 class="docs-section-heading">Installation Guide</h2>
        
        <div class="mt-8 space-y-4">
          <div class="docs-step">
            <div class="docs-step-number">1</div>
            <div>
              <p class="font-semibold text-dark mb-1">Download & Open</p>
              <p class="text-gray text-sm leading-relaxed">Download the DMG file and double-click to open it.</p>
            </div>
          </div>

          <div class="docs-step">
            <div class="docs-step-number">2</div>
            <div>
              <p class="font-semibold text-dark mb-1">Drag to Applications</p>
              <p class="text-gray text-sm leading-relaxed">Drag Default Tamer to your Applications folder.</p>
            </div>
          </div>

          <div class="docs-step">
            <div class="docs-step-number">3</div>
            <div>
              <p class="font-semibold text-dark mb-1">Launch the App</p>
              <p class="text-gray text-sm leading-relaxed">Open Default Tamer from Applications or Spotlight (<kbd class="kbd">⌘ Space</kbd>).</p>
            </div>
          </div>

          <div class="docs-step">
            <div class="docs-step-number">4</div>
            <div>
              <p class="font-semibold text-dark mb-1">Set as Default Browser</p>
              <p class="text-gray text-sm leading-relaxed">Click "Open System Settings" in the first-run window. In System Settings → Desktop & Dock → Default web browser, select <strong class="text-dark">Default Tamer</strong>.</p>
            </div>
          </div>

          <div class="docs-step">
            <div class="docs-step-number">5</div>
            <div>
              <p class="font-semibold text-dark mb-1">Configure & Enjoy</p>
              <p class="text-gray text-sm leading-relaxed">Choose your fallback browser, and you're done! Slack and Cursor links will automatically open in Chrome.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- System Requirements -->
      <section id="requirements">
        <h2 class="docs-section-heading">System Requirements</h2>
        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">✅</div>
              <h3 class="text-base font-bold text-primary">macOS Version</h3>
            </div>
            <p class="text-gray text-sm">macOS 13.0 (Ventura) or later</p>
          </div>
          <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">💾</div>
              <h3 class="text-base font-bold text-primary">Disk Space</h3>
            </div>
            <p class="text-gray text-sm">~10MB available space</p>
          </div>
          <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">🖥️</div>
              <h3 class="text-base font-bold text-primary">Architecture</h3>
            </div>
            <p class="text-gray text-sm">Apple Silicon & Intel supported</p>
          </div>
          <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">🔐</div>
              <h3 class="text-base font-bold text-primary">Permissions</h3>
            </div>
            <p class="text-gray text-sm">No special permissions required</p>
          </div>
        </div>
      </section>

      <!-- Verification -->
      <section id="verification">
        <h2 class="docs-section-heading">Verifying the Download</h2>
        <p class="mt-4 text-gray leading-relaxed">
          Default Tamer is code-signed and notarized by Apple. 
          Your Mac will verify the app automatically when you first open it.
        </p>
        <div class="callout-info mt-6">
          <strong>Note:</strong> If you see a security prompt, right-click the app 
          and select "Open" to confirm you want to run it.
        </div>
      </section>

      <!-- What's Next -->
      <section id="whats-next">
        <h2 class="docs-section-heading">What's Next?</h2>
        <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/docs" data-umami-event="Docs CTA Click" data-umami-event-source="download-whats-next" class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl no-underline">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">📖</div>
              <h3 class="text-base font-bold text-primary">Documentation</h3>
            </div>
            <p class="text-gray text-sm">Setup, rules, troubleshooting, and FAQ</p>
          </a>
          <a href="https://github.com/0xdps/default-tamer" target="_blank" rel="noopener noreferrer" data-umami-event="GitHub Click" data-umami-event-source="download-whats-next" class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl no-underline">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">💻</div>
              <h3 class="text-base font-bold text-primary">GitHub</h3>
            </div>
            <p class="text-gray text-sm">Source code, issues, and discussions</p>
          </a>
          <a href="/changelog" data-umami-event="Changelog Click" data-umami-event-source="download-whats-next" class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl no-underline">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-2xl">📋</div>
              <h3 class="text-base font-bold text-primary">Changelog</h3>
            </div>
            <p class="text-gray text-sm">What's new in each release</p>
          </a>
        </div>

        <div class="mt-8 p-6 bg-gradient-to-r from-primary/5 to-orange-50 border-2 border-primary/20 rounded-xl text-center">
          <p class="text-lg font-semibold text-dark mb-2">Enjoying Default Tamer? ☕</p>
          <p class="text-gray text-sm mb-4">If this app saves you time, consider supporting its development.</p>
          <a href="https://buymeacoffee.com/0xdps" target="_blank" rel="noopener noreferrer" data-umami-event="Buy Me a Coffee Click" data-umami-event-source="download-whats-next" class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary-dark transition-all duration-200">
            Buy Me a Coffee
          </a>
        </div>
      </section>

        </div>
      </div>
    </div>
  </div>
</BaseLayout>
