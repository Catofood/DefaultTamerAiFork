---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

// Load all user-facing changelog entries, sorted newest first
const entries = (await getCollection('changelog')).sort((a, b) =>
  b.data.version.localeCompare(a.data.version, undefined, { numeric: true })
);

interface Release {
  version: string;
  date: string;
  isUnreleased: boolean;
  contentHtml: string;
  downloadUrl: string | null;
}

// Replace markdown-generated <h3> category headings with styled badge divs
function styleCategoryHeadings(html: string): string {
  const catClasses: Record<string, string> = {
    Added:    'changelog-cat-added',
    Changed:  'changelog-cat-changed',
    Updated:  'changelog-cat-changed',
    Improved: 'changelog-cat-changed',
    Fixed:    'changelog-cat-fixed',
    Removed:  'changelog-cat-removed',
    Security: 'changelog-cat-security',
  };
  let result = html.replace(
    /<h3>(Added|Changed|Updated|Improved|Fixed|Removed|Security)<\/h3>/g,
    (_, cat: string) => {
      const cls = catClasses[cat] ?? 'changelog-cat-default';
      return `<div class="changelog-category ${cls}">${cat}</div>`;
    }
  );
  // Style "Also in this update" and "A note on …" sub-section headings
  result = result.replace(
    /<h3>((?:Also in this update|A note on)[^<]*)<\/h3>/g,
    (_, text: string) => `<div class="changelog-category changelog-cat-default">${text}</div>`
  );
  return result;
}

const releases: Release[] = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    // render() gives us a component — we need raw HTML for Fragment set:html
    // Use Astro's experimental container or a simpler marked re-parse of the raw body
    const { marked } = await import('marked');
    const contentHtml = styleCategoryHeadings(await marked.parse(entry.body ?? ''));
    return {
      version: entry.data.version,
      date: entry.data.date,
      isUnreleased: entry.data.isUnreleased ?? false,
      contentHtml,
      downloadUrl: entry.data.isUnreleased
        ? null
        : `/download/DefaultTamer-v${entry.data.version}.dmg`,
    };
  })
);

const MAX_RELEASES = 10;
const hasMore = releases.length > MAX_RELEASES;
const visibleReleases = releases.slice(0, MAX_RELEASES);
const GITHUB_CHANGELOG_URL = 'https://github.com/0xdps/default-tamer/blob/trunk/CHANGELOG.md';
---

<BaseLayout
  title="Changelog – Default Tamer Release History"
  description="Every release of Default Tamer for macOS. See what's new, what's fixed, and download any version."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.defaulttamer.app" },
      { "@type": "ListItem", "position": 2, "name": "Changelog", "item": "https://www.defaulttamer.app/changelog" }
    ]
  }}
>
  <div class="hero-section py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
        <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Changelog</span>
      </h1>
      <p class="mt-3 text-lg text-gray-300">What's new in each release</p>
    </div>
  </div>

  <div class="bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
      <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-16">

        <!-- Sticky sidebar TOC -->
        <aside class="hidden lg:block">
          <div class="sticky top-28 space-y-1">
            <p class="text-xs font-bold uppercase tracking-widest text-gray mb-4">Releases</p>
            <nav class="flex flex-col gap-0.5">
              {visibleReleases.map((r) => (
                <a
                  href={r.isUnreleased ? '#upcoming' : `#v${r.version.replace(/\./g, '-')}`}
                  class="toc-link"
                >
                  {r.isUnreleased ? 'Upcoming' : `v${r.version}`}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- Main content -->
        <div class="min-w-0">
      {releases.length === 0 ? (
        <p class="text-center text-gray">No releases yet.</p>
      ) : (
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-0 top-3 bottom-3 w-0.5 bg-gray-light hidden sm:block"></div>

          <div class="space-y-16">
            {visibleReleases.map((release) => (
              <div class="sm:pl-10 relative" id={release.isUnreleased ? 'upcoming' : undefined}>
                <!-- Timeline dot -->
                <div class="hidden sm:flex absolute -left-[9px] top-7 w-[18px] h-[18px] rounded-full border-2 border-primary bg-white items-center justify-center">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>

                <!-- Release card -->
                <div class={`bg-white border-2 rounded-xl p-6 transition-colors duration-300 ${release.isUnreleased ? 'border-primary/40 bg-primary/[0.02]' : 'border-gray-light hover:border-primary'}`}>
                  <!-- Version header -->
                  <div class="flex flex-wrap items-center gap-3 mb-5 pb-5 border-b-2 border-gray-light">
                    {release.isUnreleased ? (
                      <>
                        <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 border border-primary/30 px-3 py-1 text-xs font-bold tracking-widest uppercase text-primary font-heading">
                          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse inline-block"></span>
                          Upcoming
                        </span>
                        <span class="text-xs text-gray ml-auto">Not yet released</span>
                      </>
                    ) : (
                      <>
                        <h2 id={`v${release.version.replace(/\./g, '-')}`} class="text-2xl font-bold text-dark font-heading m-0">v{release.version}</h2>
                        {release.date && (
                          <time class="text-sm text-gray bg-gray-lighter px-3 py-1 rounded-full">{release.date}</time>
                        )}
                        <a
                          href={release.downloadUrl!}
                          data-umami-event="Download App"
                          data-umami-event-version={release.version}
                          data-umami-event-source="changelog"
                          class="ml-auto inline-flex items-center gap-1.5 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-dark hover:bg-primary-dark transition-colors duration-200 no-underline"
                        >
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                          </svg>
                          Download .dmg
                        </a>
                      </>
                    )}
                  </div>

                  <!-- Release content -->
                  <div class="changelog-content">
                    <Fragment set:html={release.contentHtml} />
                  </div>
                </div>
              </div>
            ))}
          </div>

          {hasMore && (
            <div class="sm:pl-10 mt-12 pt-10 border-t-2 border-gray-light">
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <div>
                  <p class="text-sm font-semibold text-dark m-0">Looking for older releases?</p>
                  <p class="text-sm text-gray mt-1 m-0">The full history is available on GitHub.</p>
                </div>
                <a
                  href={GITHUB_CHANGELOG_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-umami-event="GitHub Click"
                  data-umami-event-source="changelog"
                  class="sm:ml-auto inline-flex items-center gap-2 rounded-lg border-2 border-gray-light px-4 py-2.5 text-sm font-semibold text-dark hover:border-primary hover:text-primary transition-colors duration-200 no-underline shrink-0"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  View full changelog on GitHub
                </a>
              </div>
            </div>
          )}
        </div>
      )}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
