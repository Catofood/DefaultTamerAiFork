---
import BaseLayout from '../layouts/BaseLayout.astro';
import latestRelease from '../data/release.json';

const dmgSize = latestRelease.size
  ? `~${(latestRelease.size / (1024 * 1024)).toFixed(1)} MB`
  : '~2 MB';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Default Tamer",
    "headline": "Open every link in the right browser — automatically",
    "description": "Set Default Tamer as your default browser once. Links from Slack open in Chrome, work URLs open in Firefox, personal links open in Safari — automatically, based on rules you define.",
    "url": "https://www.defaulttamer.app",
    "downloadUrl": `https://www.defaulttamer.app/download/DefaultTamer-v${latestRelease.version}.dmg`,
    "softwareVersion": latestRelease.version,
    "operatingSystem": "macOS 13.0 Ventura or later",
    "applicationCategory": "UtilitiesApplication",
    "applicationSubCategory": "Productivity",
    "keywords": "macOS browser routing, URL router, default browser manager, open links in specific browser, Slack Chrome Firefox Safari routing, menu bar app",
    "license": "https://opensource.org/licenses/MIT",
    "isAccessibleForFree": true,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "featureList": [
      "Route URLs to specific browsers based on rules",
      "Match by source app, domain, URL pattern, or regex",
      "Menu bar app — no dock icon",
      "URL routing is 100% local — your browsing stays on your Mac",
      "Open source under MIT license",
      "Supports Chrome, Firefox, Safari, Arc, Brave, Edge and more"
    ],
    "screenshot": "https://www.defaulttamer.app/images/icon-512.png",
    "author": {
      "@type": "Person",
      "name": "0xdps",
      "url": "https://github.com/0xdps"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Default Tamer",
      "url": "https://www.defaulttamer.app"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Default Tamer",
    "url": "https://www.defaulttamer.app",
    "description": "Intelligent browser routing for macOS. Open source, privacy-first.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.defaulttamer.app/docs?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does it collect any data?",
        "acceptedAnswer": { "@type": "Answer", "text": "URL routing is 100% local — your URLs are never sent to any server. Default Tamer includes optional, anonymous usage analytics (disabled by default) you can opt into in Preferences. No URLs, no browsing history, and no personal information are ever collected. See our privacy policy for the full details." }
      },
      {
        "@type": "Question",
        "name": "How does it actually work?",
        "acceptedAnswer": { "@type": "Answer", "text": "You set Default Tamer as your default browser. When any app opens a link, macOS sends it to Default Tamer first. It checks your rules (source app, domain, URL pattern) and instantly routes the link to the right browser. The whole process takes under 1ms." }
      },
      {
        "@type": "Question",
        "name": "What if I want to uninstall it?",
        "acceptedAnswer": { "@type": "Answer", "text": "Just change your default browser back in System Settings and delete the app. Default Tamer doesn't install any background services, kernel extensions, or system modifications. It's a clean, sandboxed macOS app." }
      }
    ]
  }
];
---

<BaseLayout 
  title="Default Tamer – Send Every Link to the Right Browser on macOS"
  description="Tired of every link opening in the wrong browser? Default Tamer lets you route Slack links to Chrome, work URLs to Firefox, personal links to Safari — automatically. Free, open source, privacy-first."
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="hero-section relative flex items-center">
    <!-- Decorative SVG background — preloaded for LCP optimization -->
    <div id="hero-bg" class="absolute inset-0 pointer-events-none z-0 overflow-hidden bg-center bg-no-repeat bg-contain opacity-10" style="background-image: url('/images/routing-flow.svg');"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 mb-8">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary ring-1 ring-inset ring-primary/20 backdrop-blur-sm">macOS 13.0+</span>
          <span class="inline-flex items-center rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold text-white ring-1 ring-inset ring-white/20 backdrop-blur-sm">v{latestRelease.version}</span>
        </div>
        <p class="text-base sm:text-lg text-gray-400 mb-4 drop-shadow-md">Stop copy‑pasting links between browsers</p>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl drop-shadow-lg">
          Open Every Link in<br />
          <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">the Right Browser</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-300 max-w-2xl mx-auto drop-shadow-md">
          Never switch browsers manually again. Default Tamer routes links where they belong based on the app or domain — automatically.
        </p>

        <!-- Visual routing diagram -->
        <div class="mt-10 mx-auto max-w-lg">
          <div class="grid grid-cols-3 gap-3 text-sm">
            <div class="backdrop-blur-sm bg-white/10 rounded-xl px-4 py-3 text-center ring-1 ring-white/10">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 mx-auto mb-1"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313z" fill="#E01E5A"/><path d="M8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312z" fill="#36C5F0"/><path d="M18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312z" fill="#2EB67D"/><path d="M15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z" fill="#ECB22E"/></svg>
              <span class="font-semibold text-white">Slack link</span>
              <span class="block text-primary font-bold mt-1">→ Chrome</span>
            </div>
            <div class="backdrop-blur-sm bg-white/10 rounded-xl px-4 py-3 text-center ring-1 ring-white/10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 98 96" class="w-8 h-8 mx-auto mb-1"><path fill-rule="evenodd" clip-rule="evenodd" d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z" fill="#fff"/></svg>
              <span class="font-semibold text-white">github.com</span>
              <span class="block text-primary font-bold mt-1">→ Firefox</span>
            </div>
            <div class="backdrop-blur-sm bg-white/10 rounded-xl px-4 py-3 text-center ring-1 ring-white/10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 mx-auto mb-1"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <span class="font-semibold text-white">Everything else</span>
              <span class="block text-primary font-bold mt-1">→ Safari</span>
            </div>
          </div>
          <p class="mt-3 text-xs text-gray-500 drop-shadow-md">Install once, set as default browser, done. Takes under 3 minutes.</p>
        </div>

        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a href="/download" data-umami-event="Hero Download Click" data-umami-event-source="hero" class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-dark shadow-sm hover:bg-primary-dark transition-all duration-200 hover:scale-105">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download for macOS
          </a>
          <a href="https://github.com/0xdps/default-tamer" target="_blank" rel="noopener noreferrer" data-umami-event="GitHub Click" data-umami-event-source="hero" class="text-sm font-semibold leading-6 text-white hover:text-primary transition-colors duration-200">
            View on GitHub <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="mt-16 flex items-center justify-center gap-x-12">
          <div class="text-center backdrop-blur-sm bg-dark/30 rounded-xl px-6 py-4">
            <div class="text-3xl font-bold text-white">100%</div>
            <div class="mt-1 text-sm text-gray-300">Privacy-First</div>
          </div>
          <div class="text-center backdrop-blur-sm bg-dark/30 rounded-xl px-6 py-4">
            <div class="text-3xl font-bold text-white">Opt-in</div>
            <div class="mt-1 text-sm text-gray-300">Analytics</div>
          </div>
          <div class="text-center backdrop-blur-sm bg-dark/30 rounded-xl px-6 py-4">
            <div class="text-3xl font-bold text-white">Open</div>
            <div class="mt-1 text-sm text-gray-300">Source</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Problem → Solution -->
      <div class="max-w-3xl mx-auto mb-20">
        <div class="text-center">
          <h2 class="text-3xl font-bold tracking-tight text-dark sm:text-4xl">No More Copy‑Pasting Links Between Browsers</h2>
          <p class="mt-4 text-lg text-gray leading-relaxed">
            macOS only lets you use <strong class="text-dark">one</strong> default browser. That means Slack links open in Safari even if you always use Chrome for work. A Figma link from a teammate? Also Safari. You waste time copying URLs and pasting them into the right browser.
          </p>
        </div>

        <!-- Before / After -->
        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="rounded-xl border-2 border-red-200 bg-red-50 p-6">
            <p class="text-sm font-bold text-red-700 uppercase tracking-wide mb-4">Without Default Tamer</p>
            <ul class="space-y-3 text-sm text-gray">
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✕</span> Every link opens in one browser</li>
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✕</span> Copy URL → open correct browser → paste</li>
              <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✕</span> Work and personal tabs mixed together</li>
            </ul>
          </div>
          <div class="rounded-xl border-2 border-green-200 bg-green-50 p-6">
            <p class="text-sm font-bold text-green-700 uppercase tracking-wide mb-4">With Default Tamer</p>
            <ul class="space-y-3 text-sm text-gray">
              <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> Slack links → Chrome automatically</li>
              <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> github.com → Firefox automatically</li>
              <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> Everything else → your fallback browser</li>
            </ul>
          </div>
        </div>

        <p class="mt-8 text-center text-base text-gray leading-relaxed">
          Windows users have had browser routing tools for years. <strong class="text-dark">macOS never had a great answer — until now.</strong>
          Default Tamer brings proper browser routing to the Mac: free, open source, and built for the way you actually work.
        </p>
      </div>

      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-dark sm:text-4xl">Powerful Features</h2>
        <p class="mt-4 text-lg text-gray">Set it up once — links go to the right browser automatically</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">🎯</div>
            <h3 class="text-xl font-bold text-orange-700">Smart Routing</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Route links based on source app. Slack and Cursor links automatically open in Chrome.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">🌐</div>
            <h3 class="text-xl font-bold text-orange-700">Domain Rules</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Send specific domains to specific browsers. Exact, suffix, or contains matching.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">⌥</div>
            <h3 class="text-xl font-bold text-orange-700">Override Chooser</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Hold Option key while clicking any link to choose browser on the fly.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">🔄</div>
            <h3 class="text-xl font-bold text-orange-700">Fallback Browser</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Configurable default browser for links that don't match any rules.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">🚀</div>
            <h3 class="text-xl font-bold text-orange-700">Launch at Login</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Optionally start at system login for seamless routing.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">📊</div>
            <h3 class="text-xl font-bold text-orange-700">Route History</h3>
          </div>
          <p class="text-gray leading-relaxed">
            See which links went where, so you can fine-tune your rules.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">🔒</div>
            <h3 class="text-xl font-bold text-orange-700">Privacy First</h3>
          </div>
          <p class="text-gray leading-relaxed">
            URL routing stays on your Mac. Optional, anonymous analytics are opt-in only — never your URLs or browsing history.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">✨</div>
            <h3 class="text-xl font-bold text-orange-700">Menu Bar App</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Clean, minimal interface that stays out of your way.
          </p>
        </div>
      </div>


    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-24 bg-gray-lighter">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-dark sm:text-4xl">Setup Takes Under 3 Minutes</h2>
        <p class="mt-4 text-lg text-gray">Install once, set as default browser, add your rules — done. No terminal commands, no config files.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="relative">
          <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-full text-white text-2xl font-bold mb-6">
            1
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Download & Install</h3>
          <p class="text-gray leading-relaxed">
            Download Default Tamer and move it to your Applications folder.
          </p>
        </div>

        <div class="relative">
          <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-full text-white text-2xl font-bold mb-6">
            2
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Set as Default Browser</h3>
          <p class="text-gray leading-relaxed">
            Open System Settings and set Default Tamer as your default web browser.
          </p>
        </div>

        <div class="relative">
          <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-full text-white text-2xl font-bold mb-6">
            3
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Configure Rules</h3>
          <p class="text-gray leading-relaxed">
            Choose your fallback browser and customize routing rules to your workflow.
          </p>
        </div>

        <div class="relative">
          <div class="flex items-center justify-center w-16 h-16 bg-gradient-to-br from-primary to-secondary rounded-full text-white text-2xl font-bold mb-6">
            4
          </div>
          <h3 class="text-xl font-bold text-dark mb-3">Done!</h3>
          <p class="text-gray leading-relaxed">
            Links now automatically open in the right browser. Hold ⌥ Option to override.
          </p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/docs" data-umami-event="Docs CTA Click" data-umami-event-source="how-it-works" class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-dark hover:bg-primary-dark transition-all duration-200">
          Full Setup Guide <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Use Cases Section -->
  <section class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-dark sm:text-4xl">Perfect For Anyone Using Multiple Browsers</h2>
        <p class="mt-4 text-lg text-gray">If you juggle work and personal browsing, Default Tamer stops you from copy-pasting URLs between browsers</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">👨‍💻</div>
            <h3 class="text-xl font-bold text-orange-700">Developers</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Work links in Chrome, personal browsing in Safari, testing in Firefox.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">📱</div>
            <h3 class="text-xl font-bold text-orange-700">Product Managers</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Jira in Chrome, Figma in Arc, documentation in Safari.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="text-3xl">🎨</div>
            <h3 class="text-xl font-bold text-orange-700">Designers</h3>
          </div>
          <p class="text-gray leading-relaxed">
            Design tools in Arc, client links in Chrome, research in Safari.
          </p>
        </div>

        <div class="card-animated p-6 bg-white border-2 border-gray-light rounded-xl hover:border-primary hover:-translate-y-2 transition-all duration-300 hover:shadow-xl">
          <div class="flex items-center gap-3 mb-4">
