---
import { getCollection } from 'astro:content';
import latestRelease from '../data/release.json';

const version = latestRelease.version;

const entries = await getCollection('changelog');
const entry = entries.find((e) => e.data.version === version);

let contentHtml = '<p>No release notes available for this version.</p>';

if (entry && entry.body) {
  const { marked } = await import('marked');
  const rawHtml = await marked.parse(entry.body);

  const catColors: Record<string, string> = {
    Added: '#16a34a',
    Changed: '#f97316',
    Updated: '#f97316',
    Improved: '#f97316',
    Fixed: '#6366f1',
    Removed: '#ef4444',
    Security: '#dc2626',
  };

  contentHtml = rawHtml.replace(
    /<h3>(Added|Changed|Updated|Improved|Fixed|Removed|Security)<\/h3>/g,
    (_: string, cat: string) => {
      const color = catColors[cat] ?? '#6b7280';
      return `<span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:13px;font-weight:600;color:#fff;background:${color};margin:16px 0 8px;">${cat}</span>`;
    }
  );

  // Style "Also in this update" sub-section heading
  contentHtml = contentHtml.replace(
    /<h3>(Also in this update[^<]*)<\/h3>/g,
    (_: string, text: string) =>
      `<span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:13px;font-weight:600;color:#fff;background:#64748b;margin:16px 0 8px;">${text}</span>`
  );
}
---

<html>
  <head>
    <meta charset="utf-8" />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
        font-size: 15px;
        line-height: 1.7;
        color: #0f172a;
        background: #ffffff;
        padding: 20px 24px;
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }
      h2 { font-size: 20px; font-weight: 700; margin: 0 0 16px; color: #0f172a; }
      ul { padding-left: 22px; margin: 6px 0 14px; }
      li { margin-bottom: 6px; color: #334155; }
      a { color: #f97316; }
      @media (prefers-color-scheme: dark) {
        body { background: #1e293b; color: #e2e8f0; }
        h2 { color: #f1f5f9; }
        li { color: #cbd5e1; }
      }
    </style>
  </head>
  <body>
    <h2>Version {version}</h2>
    <Fragment set:html={contentHtml} />
  </body>
</html>
