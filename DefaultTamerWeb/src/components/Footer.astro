---
interface FooterLink {
  href: string;
  label: string;
  external?: boolean;
  umamiEvent?: string;
}

const footerColumns: { title: string; links: FooterLink[] }[] = [
  {
    title: 'Product',
    links: [
      { href: '/download', label: 'Download', umamiEvent: 'Footer Download Click' },
      { href: '/changelog', label: 'Changelog' },
    ]
  },
  {
    title: 'Resources',
    links: [
      { href: '/docs', label: 'Documentation' },
      { href: '/privacy', label: 'Privacy Policy' },
      { href: 'https://github.com/0xdps/default-tamer', label: 'GitHub', external: true, umamiEvent: 'GitHub Click' },
      { href: 'https://github.com/0xdps/default-tamer/issues', label: 'Support', external: true, umamiEvent: 'Support Click' },
    ]
  },
  {
    title: 'Community',
    links: [
      { href: 'https://github.com/0xdps/default-tamer/blob/trunk/CONTRIBUTING.md', label: 'Contributing', external: true, umamiEvent: 'GitHub Click' },
      { href: 'https://github.com/0xdps/default-tamer/blob/trunk/CODE_OF_CONDUCT.md', label: 'Code of Conduct', external: true, umamiEvent: 'GitHub Click' },
      { href: 'https://github.com/0xdps/default-tamer/blob/trunk/LICENSE', label: 'License', external: true, umamiEvent: 'GitHub Click' },
      { href: 'https://buymeacoffee.com/0xdps', label: 'Buy Me a Coffee', external: true, umamiEvent: 'Buy Me a Coffee Click' },
    ]
  },
];
---

<footer class="bg-dark text-white mt-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-12">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <picture>
            <source srcset="/images/logo.webp" type="image/webp" />
            <img src="/images/logo.png" alt="" width="32" height="32" class="w-8 h-8">
          </picture>
          <span class="text-xl font-bold">Default Tamer</span>
        </div>
        <p class="text-gray-light leading-relaxed">Intelligent browser routing for macOS. Set it as your default browser once — your links open where you want, automatically.</p>
      </div>

      {footerColumns.map(column => (
        <div>
          <h3 class="font-semibold mb-4">{column.title}</h3>
          <ul class="space-y-3">
            {column.links.map(link => (
              <li>
                <a 
                  href={link.href}
                  {...(link.external && { target: '_blank', rel: 'noopener noreferrer' })}
                  {...(link.umamiEvent && { 'data-umami-event': link.umamiEvent, 'data-umami-event-source': 'footer' })}
                  class="text-gray-light hover:text-primary transition-colors duration-200 block"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-8 border-t border-dark-light text-center text-gray-light space-y-2">
      <p>&copy; 2026 Default Tamer. Released under the MIT License.</p>
      <p>Built with ❤️ for macOS</p>
    </div>
  </div>
</footer>
