---
const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<nav class="sticky top-0 z-50 bg-white border-b border-gray-light transition-all duration-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <picture>
          <source srcset="/images/logo.webp" type="image/webp" />
          <img src="/images/logo.png" alt="" width="32" height="32" class="w-8 h-8 transition-transform group-hover:scale-110">
        </picture>
        <span class="text-xl font-bold text-dark">Default Tamer</span>
      </a>
      <div class="hidden sm:flex items-center gap-6">
        <a 
          href="/docs"
          class:list={[
            "text-sm font-medium transition-colors duration-200",
            isActive('/docs') ? "text-primary font-semibold" : "text-gray hover:text-primary"
          ]}
        >Docs</a>
        <a 
          href="/download"
          class:list={[
            "text-sm font-medium transition-colors duration-200",
            isActive('/download') ? "text-primary font-semibold" : "text-gray hover:text-primary"
          ]}
        >Download</a>
        <a 
          href="/changelog"
          class:list={[
            "text-sm font-medium transition-colors duration-200",
            isActive('/changelog') ? "text-primary font-semibold" : "text-gray hover:text-primary"
          ]}
        >Changelog</a>
        <a
          href="https://github.com/0xdps/default-tamer"
          target="_blank"
          rel="noopener noreferrer"
          data-umami-event="GitHub Click"
          data-umami-event-source="header"
          class="inline-flex items-center gap-2 rounded-lg bg-dark px-4 py-2 text-sm font-semibold text-white hover:bg-dark-light transition-colors duration-200"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          GitHub
        </a>
      </div>
      <!-- Mobile hamburger button -->
      <button data-dialog-trigger="mobile-menu" class="sm:hidden p-2 text-dark hover:text-primary transition-colors" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu dialog -->
<dialog id="mobile-menu" class="fixed inset-0 z-[100] m-0 w-full h-full bg-transparent open:flex p-0">
  <div class="ml-auto w-72 h-full bg-white shadow-2xl p-6 flex flex-col">
    <div class="flex items-center justify-between mb-8">
      <span class="text-lg font-bold text-dark">Menu</span>
      <button data-dialog-close class="p-2 text-gray hover:text-dark transition-colors" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
    <div class="flex flex-col gap-2">
      <a href="/docs" class:list={["block px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200", isActive('/docs') ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-lighter hover:text-primary"]}>Docs</a>
      <a href="/download" class:list={["block px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200", isActive('/download') ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-lighter hover:text-primary"]}>Download</a>
      <a href="/changelog" class:list={["block px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200", isActive('/changelog') ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-lighter hover:text-primary"]}>Changelog</a>
    </div>
    <div class="mt-auto pt-6 border-t border-gray-light">
      <a
        href="https://github.com/0xdps/default-tamer"
        target="_blank"
        rel="noopener noreferrer"
        data-umami-event="GitHub Click"
        data-umami-event-source="header-mobile"
        class="flex items-center gap-2 px-4 py-3 rounded-lg bg-dark text-white text-sm font-semibold hover:bg-dark-light transition-colors duration-200"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>
  </div>
  <div class="fixed inset-0 bg-black/50" data-dialog-close></div>
</dialog>


