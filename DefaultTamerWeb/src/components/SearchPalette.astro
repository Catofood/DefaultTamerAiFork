---
interface PageItem {
  title: string;
  href: string;
  section: string;
}

const pages: PageItem[] = [
  { title: 'Home', href: '/', section: 'Pages' },
  { title: 'Download', href: '/download', section: 'Pages' },
  { title: 'Changelog', href: '/changelog', section: 'Pages' },
  { title: 'Docs', href: '/docs', section: 'Docs' },
];

const grouped = pages.reduce<Record<string, PageItem[]>>((acc, page) => {
  (acc[page.section] = acc[page.section] || []).push(page);
  return acc;
}, {});

const sections = Object.entries(grouped);
---

<dialog id="search-palette" class="fixed inset-0 z-[200] m-0 w-full h-full bg-transparent open:flex items-start justify-center pt-[20vh]">
  <div class="w-full max-w-lg bg-white rounded-xl shadow-2xl ring-1 ring-black/10 overflow-hidden" data-dialog-close-ignore>
    <div class="p-4 border-b border-gray-light">
      <input
        type="text"
        id="search-input"
        placeholder="Search pages..."
        autocomplete="off"
        class="w-full text-lg text-dark placeholder:text-gray/50 outline-none bg-transparent"
      />
    </div>
    <div id="search-results" class="max-h-80 overflow-y-auto p-2">
      {sections.map(([sectionName, sectionItems]) => (
        <div class="search-group" data-section={sectionName}>
          <div class="px-3 py-2 text-xs font-semibold text-gray uppercase tracking-wider">{sectionName}</div>
          {sectionItems.map((item) => (
            <a
              href={item.href}
              class="search-item block px-3 py-2.5 rounded-lg text-sm text-dark hover:bg-primary/10 hover:text-primary transition-colors duration-150"
              data-title={item.title.toLowerCase()}
            >
              {item.title}
            </a>
          ))}
        </div>
      ))}
      <div id="search-empty" class="hidden px-3 py-8 text-center text-gray text-sm">No results found.</div>
    </div>
    <div class="px-4 py-3 border-t border-gray-light flex items-center justify-between text-xs text-gray">
      <span>Navigate with <kbd class="bg-gray-lighter px-1.5 py-0.5 rounded text-xs font-mono">↑↓</kbd></span>
      <span><kbd class="bg-gray-lighter px-1.5 py-0.5 rounded text-xs font-mono">esc</kbd> to close</span>
    </div>
  </div>
  <div class="fixed inset-0 bg-black/50"></div>
</dialog>

<script>
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const dialog = document.getElementById('search-palette') as HTMLDialogElement;
      if (dialog && !dialog.open) {
        dialog.showModal();
        (window as any).umami?.track('Search Opened');
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        if (searchInput) {
          searchInput.focus();
          searchInput.value = '';
          filterResults('');
        }
      }
    }
  });

  const searchField = document.getElementById('search-input');
  searchField?.addEventListener('input', (e) => {
    filterResults((e.target as HTMLInputElement).value.toLowerCase());
  });

  function filterResults(query: string) {
    const groups = document.querySelectorAll('.search-group') as NodeListOf<HTMLElement>;
    const empty = document.getElementById('search-empty');
    let hasResults = false;

    groups.forEach(group => {
      let groupHasMatch = false;
      group.querySelectorAll('.search-item').forEach((el) => {
        const item = el as HTMLAnchorElement;
        const match = !query || item.dataset.title?.includes(query);
        item.style.display = match ? '' : 'none';
        if (match) { groupHasMatch = true; hasResults = true; }
      });
      group.style.display = groupHasMatch ? '' : 'none';
    });

    if (empty) empty.style.display = hasResults ? 'none' : 'block';
  }
</script>
